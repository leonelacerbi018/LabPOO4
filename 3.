class Animal:
    def __init__(self, nombre, especie):
        self.nombre = nombre
        self.especie = especie
    
    def mostrar_detalles(self):
        print(f"Nombre: {self.nombre} | Especie: {self.especie}")

class Perro(Animal):
    def __init__(self, nombre):
        super().__init__(nombre, "Perro")
    
    def emitir_sonido(self):
        return "Guauguau"

class Gato(Animal):
    def __init__(self, nombre):
        super().__init__(nombre, "Gato")
    
    def emitir_sonido(self):
        return "Miau"

if __name__ == "__main__":
    p = Perro("Firulais")
    g = Gato("Michi")
    
    p.mostrar_detalles()
    print(f"Sonido: {p.emitir_sonido()}\n")
    
    g.mostrar_detalles()
    print(f"Sonido: {g.emitir_sonido()}")

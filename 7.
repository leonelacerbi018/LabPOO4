class Instrumento:
    def __init__(self, nombre, material, tipo_sonido):
        self.nombre = nombre
        self.material = material
        self.tipo_sonido = tipo_sonido

    def indicar_tipo_sonido(self):
        print(f"El instrumento {self.nombre} es de tipo: {self.tipo_sonido}")


class Guitarra(Instrumento):
    def __init__(self, nombre, material):
        super().__init__(nombre, material, "Cuerdas")

    def tocar_nota(self, nota):
        return f"Sonando la cuerda en la nota {nota}"


class Piano(Instrumento):
    def __init__(self, nombre, material):
        super().__init__(nombre, material, "Teclado")

    def tocar_nota(self, nota):
        return f"Tocando la tecla en la nota {nota}"


if __name__ == "__main__":
    guitarra = Guitarra("Guitarra clásica", "Madera")
    piano = Piano("Pianito", "Madera")

    guitarra.indicar_tipo_sonido()
    print(guitarra.tocar_nota("Do"))
    piano.indicar_tipo_sonido()
    print(piano.tocar_nota("Sol"))
